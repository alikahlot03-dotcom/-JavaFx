<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>
    <VBox alignment="CENTER" maxWidth="600" spacing="15.0" styleClass="card">
        <Label styleClass="header-label" text="Welcome to your Dashboard!" />
        <Label alignment="CENTER" styleClass="secondary-label" text="Track your income, manage your expenses, and achieve your financial goals with ease." wrapText="true" />
    </VBox>
</VBox>
