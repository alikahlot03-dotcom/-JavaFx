{
    "java.project.sourcePaths": [
        "src"
    ],
    "java.project.outputPath": "out",
    "java.project.referencedLibraries": [
        "lib/**/*.jar"
    ],
    "java.debug.settings.vmArgs": "--module-path \"${workspaceFolder}/lib\" --add-modules javafx.controls,javafx.fxml,javafx.graphics,javafx.base",
    "java.debug.settings.onBuildFailureProceed": true
}