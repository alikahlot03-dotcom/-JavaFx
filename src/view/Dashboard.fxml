<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1000.0" stylesheets="@../css/styleProject.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FinanceTrackerController.DashboardController">
    
    <left>
        <VBox id="sidebar" prefWidth="250" spacing="10" styleClass="sidebar-container">
            <padding>
                <Insets bottom="30" left="20" right="20" top="30" />
            </padding>
            
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 30 0;" text="FINANCE TRACKER" />
            
            <Button fx:id="dashboardBtn" maxWidth="Infinity" styleClass="active-nav" text="Dashboard Overview" />
            <Button fx:id="categoriesBtn" maxWidth="Infinity" text="Budget Categories" />
            <Button fx:id="transactionsBtn" maxWidth="Infinity" text="Recent Transactions" />
            <Button fx:id="reportsBtn" maxWidth="Infinity" text="Financial Reports" />
            
            <VBox VBox.vgrow="ALWAYS" />
            
            <Button fx:id="logoutBtn" maxWidth="Infinity" style="-fx-text-fill: #e74c3c;" text="Logout" />
        </VBox>
    </left>
    
    <center>
        <VBox alignment="CENTER" spacing="15.0">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>
            <VBox alignment="CENTER" maxWidth="600" spacing="15.0" styleClass="card">
                <Label fx:id="welcomeLabel" styleClass="header-label" text="Welcome to your Dashboard!" />
                <Label alignment="CENTER" styleClass="secondary-label" text="Track your income, manage your expenses, and achieve your financial goals with ease." wrapText="true" />
            </VBox>
        </VBox>
    </center>
    
</BorderPane>
