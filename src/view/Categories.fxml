<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" stylesheets="@../css/styleProject.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FinanceTrackerController.CategoriesController">
   <padding>
      <Insets bottom="30" left="30" right="30" top="30" />
   </padding>
   <children>
      <VBox alignment="TOP_CENTER" maxWidth="600" spacing="20.0" styleClass="card">
         <children>
            <Label styleClass="header-label" text="Categories Management" />
            
            <VBox alignment="CENTER_LEFT" spacing="5">
               <Label styleClass="secondary-label" text="Category Name" />
               <TextField fx:id="txtCategoryName" maxWidth="Infinity" promptText="Enter category name..." styleClass="text-field" />
            </VBox>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="btnAdd" onAction="#HandelButtonAdd" styleClass="primary-button" text="Add Category" />
                  <Button fx:id="btnDelete" onAction="#handleDeleteCategory" styleClass="danger-button" text="Delete Selected" />
               </children>
            </HBox>

            <TableView fx:id="tableCategories" prefHeight="250.0" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="300.0" text="Category Name" />
              </columns>
              <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
              </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>