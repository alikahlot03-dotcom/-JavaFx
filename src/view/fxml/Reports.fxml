<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/styleProject.css" spacing="20">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox spacing="25" styleClass="card" VBox.vgrow="ALWAYS" maxWidth="Infinity">
        <Label text="Financial Reports &amp; Analytics" styleClass="header-label" />
        <Label text="Visualise your financial health and spending patterns." styleClass="secondary-label" />
        
        <HBox spacing="25" alignment="CENTER">
            <VBox alignment="CENTER" spacing="15" style="-fx-background-color: rgba(46, 204, 113, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: #2ecc71; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                <Label text="Total Income" styleClass="secondary-label" />
                <Label text="$12,450.00" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
            </VBox>
            <VBox alignment="CENTER" spacing="15" style="-fx-background-color: rgba(231, 76, 60, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: #e74c3c; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                <Label text="Total Expenses" styleClass="secondary-label" />
                <Label text="$8,920.00" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
            </VBox>
        </HBox>
        
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Monthly Spending Trend" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Region VBox.vgrow="ALWAYS" style="-fx-background-color: #fcfcfc; -fx-border-color: #f1f2f6; -fx-border-radius: 8;" />
        </VBox>
        
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Export to PDF" styleClass="button" style="-fx-background-color: -fx-secondary-color;" />
            <Button text="Print Report" styleClass="button" />
        </HBox>
    </VBox>
</VBox>
