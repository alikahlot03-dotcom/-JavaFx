<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1000.0" stylesheets="@../../css/styleProject.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FinanceTrackerController.DashboardController">
    
    <left>
        <VBox id="sidebar" spacing="10" prefWidth="250" styleClass="sidebar-container">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>
            
            <Label text="FINANCE TRACKER" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 30 0;"/>
            
            <Button fx:id="dashboardBtn" text="Dashboard Overview" maxWidth="Infinity" styleClass="active-nav" />
            <Button fx:id="categoriesBtn" text="Budget Categories" maxWidth="Infinity" />
            <Button fx:id="transactionsBtn" text="Recent Transactions" maxWidth="Infinity" />
            <Button fx:id="reportsBtn" text="Financial Reports" maxWidth="Infinity" />
            
            <VBox VBox.vgrow="ALWAYS" />
            
            <Button fx:id="logoutBtn" text="Logout" maxWidth="Infinity" style="-fx-text-fill: #e74c3c;" />
        </VBox>
    </left>
    
    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <VBox alignment="CENTER" spacing="30" styleClass="card" maxWidth="600">
                <Label fx:id="welcomeLabel" styleClass="header-label" text="Welcome to your Dashboard!" />
                <Label text="Track your income, manage your expenses, and achieve your financial goals with ease." styleClass="secondary-label" wrapText="true" alignment="CENTER" />
            </VBox>
        </VBox>
    </center>
    
</BorderPane>