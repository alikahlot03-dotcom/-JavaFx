<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="FinanceTrackerController.TransactionsController"
      spacing="20"
      prefHeight="700.0"
      prefWidth="1000.0"
      stylesheets="@../css/styleProject.css">

    <padding>
        <Insets top="30"
                right="30"
                bottom="30"
                left="30"/>
    </padding>

    
    
    <!-- قسم إضافة عملية جديدة -->

    <VBox spacing="15"
          styleClass="card"
          maxWidth="Infinity">

        <Label text="Add New Transaction"
               styleClass="header-label" />

        <GridPane hgap="15"
                  vgap="15">

            <columnConstraints>

                <ColumnConstraints minWidth="100"
                                   prefWidth="120" />

                <ColumnConstraints hgrow="ALWAYS" />

                <ColumnConstraints minWidth="100"
                                   prefWidth="120" />

                <ColumnConstraints hgrow="ALWAYS" />

            </columnConstraints>

            <rowConstraints>

                <RowConstraints />
                <RowConstraints />

            </rowConstraints>

            <children>

                <Label text="Amount:"
                       styleClass="secondary-label"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0" />

                <TextField fx:id="amountField"
                           promptText="e.g. 50.0"
                           styleClass="text-field"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0" />



                <Label text="Date:"
                       styleClass="secondary-label"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="0" />

                <DatePicker fx:id="datePicker"
                            maxWidth="Infinity"
                            GridPane.columnIndex="3"
                            GridPane.rowIndex="0" />



                <Label text="Category:"
                       styleClass="secondary-label"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1" />

                <ComboBox fx:id="categoryComboBox"
                          maxWidth="Infinity"
                          promptText="Select Category"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1" />



                <Label text="Type:"
                       styleClass="secondary-label"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1" />

                <ComboBox fx:id="typeComboBox"
                          maxWidth="Infinity"
                          promptText="Select Type"
                          GridPane.columnIndex="3"
                          GridPane.rowIndex="1" />

            </children>

        </GridPane>

        
        
        <HBox alignment="CENTER_RIGHT">

            <Button fx:id="addButton"
                    text="Add Transaction"
                    onAction="#handleAddTransaction"
                    styleClass="primary-button" />

        </HBox>

    </VBox>

    
    
    
    <!-- جدول عرض العمليات -->

    <VBox spacing="10"
          VBox.vgrow="ALWAYS"
          styleClass="card">

        <Label text="Recent Transactions"
               styleClass="header-label" />

        <TableView fx:id="transactionsTable"
                   VBox.vgrow="ALWAYS"
                   styleClass="table-view">

            <columns>

                <TableColumn fx:id="idColumn"
                             text="ID"
                             prefWidth="50" />

                <TableColumn fx:id="categoryColumn"
                             text="Category"
                             prefWidth="150" />

                <TableColumn fx:id="amountColumn"
                             text="Amount"
                             prefWidth="100" />

                <TableColumn fx:id="typeColumn"
                             text="Type"
                             prefWidth="100" />

                <TableColumn fx:id="dateColumn"
                             text="Date"
                             prefWidth="120" />

            </columns>

            
            
            <placeholder>

                <Label text="No transactions found." />

            </placeholder>

            
            
            <columnResizePolicy>

                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />

            </columnResizePolicy>

        </TableView>

    </VBox>

</VBox>