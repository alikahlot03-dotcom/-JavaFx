<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" stylesheets="@../css/styleProject.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FinanceTrackerController.ReportsController">
   <padding>
      <Insets bottom="30" left="30" right="30" top="30" />
   </padding>
   <children>
      <VBox alignment="TOP_CENTER" maxWidth="800" spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
         <children>
            <Label styleClass="header-label" text="Financial Report" />
            
            <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 10;">
               <children>
                  <VBox alignment="CENTER" spacing="5">
                     <Label styleClass="secondary-label" text="Total Income" />
                     <Label fx:id="lblIncome" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0" />
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" spacing="5">
                     <Label styleClass="secondary-label" text="Total Expenses" />
                     <Label fx:id="lblExpense" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="0" />
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" spacing="5">
                     <Label styleClass="secondary-label" text="Balance" />
                     <Label fx:id="lblBalance" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                  </VBox>
               </children>
            </HBox>

            <TableView fx:id="tableTransactions" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="250.0" text="Transaction Name" />
                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Amount" />
                <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
              </columns>
              <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
              </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>